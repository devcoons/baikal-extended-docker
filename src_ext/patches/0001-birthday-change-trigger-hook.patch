+        // baikal-ext: register the optional change-notification hook. This is a
+        // no-op when the extension is not present, so upstream Baikal keeps
+        // working unmodified. It enables event-driven birthday synchronisation.
+        $baikalExtHome = getenv('BAIKAL_EXT_HOME') ?: '/opt/baikal-ext';
+        $baikalExtBootstrap = $baikalExtHome . '/bootstrap.php';
+        if (is_readable($baikalExtBootstrap)) {
+            require_once $baikalExtBootstrap;
+            if (class_exists('\\BaikalExt\\Dav\\ChangeTriggerPlugin')) {
+                $this->server->addPlugin(new \BaikalExt\Dav\ChangeTriggerPlugin());
+            }
+        }
+
         $this->server->on('exception', [$this, 'exception']);
     }
 
